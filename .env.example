# Supabase (required for Human Bingo)
# Get these from your project: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: game code for the single shared game (default: BINGO). Must match the session in DB.
# NEXT_PUBLIC_DEFAULT_GAME_CODE=BINGO
